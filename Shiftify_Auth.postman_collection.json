                  "if (j && j.data && j.data.accessToken) { pm.collectionVariables.set('accessToken', j.data.accessToken); }",
                  "pm.test('200 OK, active=COORDINATOR', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "  pm.expect(j.data.activeRole).to.eql('COORDINATOR');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"COORDINATOR\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/switch-role", "host": ["{{baseUrl}}"], "path": ["auth", "switch-role"] }
          }
        },
        {
          "name": "8. Create Managed Participant (Coordinator)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let j; try { j = pm.response.json(); } catch (e) {}",
                  "pm.test('201 Created, MANAGED PARTICIPANT', function () {",
                  "  pm.expect(pm.response.code).to.eql(201);",
                  "  pm.expect(j.data.user.accountType).to.eql('MANAGED');",
                  "  pm.expect(j.data.user.roles).to.include('PARTICIPANT');",
                  "});",
                  "console.log('participant:', j.data.user.username, j.data.user.status);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{participantUsername}}\",\n  \"password\": \"Password@123\",\n  \"name\": \"Managed Participant (Postman)\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/linking/participants", "host": ["{{baseUrl}}"], "path": ["linking", "participants"] }
          }
        },
        {
          "name": "9. Forbidden — non-PROVIDER tries /linking/workers (expect 403)",
