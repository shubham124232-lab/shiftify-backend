{
  "info": {
    "name": "Shiftify Auth API",
    "_postman_id": "b1f2a3c4-5d6e-47f8-9a0b-1c2d3e4f5a6b",
    "description": "Shiftify multi-role auth endpoints (P0 + P1). Login/Register/Switch-Role auto-save the access token to {{accessToken}}. Refresh/Logout use the HttpOnly cookie. P1 adds OTP verify, password reset, and managed-account linking. Set {{baseUrl}} if your API isn't on http://localhost:5000.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "regEmail",    "value": "" },
    { "key": "otpCode",     "value": "" },
    { "key": "resetCode",   "value": "" },
    { "key": "workerUsername",      "value": "" },
    { "key": "participantUsername", "value": "" }
  ],
  "item": [
    {
      "name": "── P0 Auth ──",
      "item": [
        {
          "name": "Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "Register (new SELF account)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('regEmail', 'smoke+' + Date.now() + '@shiftify.local');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let j; try { j = pm.response.json(); } catch (e) {}",
                  "if (j && j.data && j.data.accessToken) { pm.collectionVariables.set('accessToken', j.data.accessToken); }",
                  "pm.test('201 Created', function () { pm.expect(pm.response.code).to.eql(201); });",
                  "pm.test('status PENDING + role assigned', function () {",
                  "  pm.expect(j.data.user.status).to.eql('PENDING');",
                  "  pm.expect(j.data.user.roles).to.include('SUPPORT_WORKER');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Smoke Test User\",\n  \"email\": \"{{regEmail}}\",\n  \"password\": \"Password@123\",\n  \"role\": \"SUPPORT_WORKER\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login - Alice (by email, multi-role)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let j; try { j = pm.response.json(); } catch (e) {}",
                  "if (j && j.data && j.data.accessToken) { pm.collectionVariables.set('accessToken', j.data.accessToken); }",
                  "pm.test('200 OK', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "pm.test('has roles + activeRole', function () {",
                  "  pm.expect(j.data.user.roles).to.include('PARTICIPANT');",
                  "  pm.expect(j.data.user.activeRole).to.be.a('string');",
                  "});",
                  "console.log('roles:', j.data.user.roles, 'active:', j.data.user.activeRole);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"alice.participant@shiftify.local\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login - Dana (managed, by username)",
          "event": [
            {
              "listen": "test",
              "script": {
