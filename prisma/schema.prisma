// Shiftify Prisma schema — Phase 1 (revised marketplace model + multi-role identity)
// Single source of truth for all database tables. Edit here, then run `npx prisma migrate dev`.
//
// Identity model (see PROJECT_CONTEXT.md §10):
//   • A self-registered account holds ONE OR MANY roles (UserRoleAssignment). The active role
//     is carried in the JWT, not stored as a column on User.
//   • Two account types: SELF (email/phone/username + password, multi-role, OTP) and
//     MANAGED (username + password only, created by a Provider/Coordinator, no email/OTP).
//   • One phone + one address per user. Job location lives on SupportRequest, not the user.
//   • Email/phone OTP and password reset are handled by VerificationCode (mock sender now,
//     Twilio/email later). Magic-link has been retired in favour of OTP.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Neon: DATABASE_URL is the POOLED connection (used at runtime); DIRECT_URL is the
  // DIRECT (non-pooled) connection used by `prisma migrate`. For a local non-Neon
  // Postgres, set DIRECT_URL to the same value as DATABASE_URL.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ───────────────────────────────────────────────────────────────────────────
// Enums
// ───────────────────────────────────────────────────────────────────────────

enum UserRole {
  PARTICIPANT
  SUPPORT_WORKER
  PROVIDER
  COORDINATOR
  PLAN_MANAGER
  ADMIN
}

// SELF  = self-registered (email/phone/username + password, multi-role, can verify via OTP)
// MANAGED = created by a Provider/Coordinator; logs in with username + password only, no OTP
enum AccountType {
  SELF
  MANAGED
}

enum UserStatus {
  PENDING
  ACTIVE      // live, operational — used for all approved/active states
  APPROVED    // legacy value kept for Postgres enum compatibility; new code uses ACTIVE
  REJECTED
  SUSPENDED
  DRAFT       // provider-managed worker mid-onboarding — not yet visible for job matching
}

enum AdminTier {
  SUPER_ADMIN
  REVIEWER
}

enum DocumentType {
  POLICE_CHECK
  NDIS_SCREENING
  WWCC
  FIRST_AID
  CPR
  MANUAL_HANDLING
