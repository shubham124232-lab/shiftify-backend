  publicLiabilityExpiryDate       DateTime?
  professionalIndemnityPolicyNumber String?
  professionalIndemnityExpiryDate DateTime?
  workersCompPolicyNumber         String?
  workersCompExpiryDate           DateTime?
  complianceDeclaration           Boolean  @default(false)

  // Step 5 — Services (structured SIL/SDA)
  coreServices                    Json?
  offersSil                       Boolean  @default(false)
  silType                         String?  // SHARED | INDIVIDUAL
  silSupportLevel                 String?  // FULL_TIME | DROP_IN
  silCurrentVacancies             Boolean?
  silDetails                      Json?
  offersSda                       Boolean  @default(false)
  sdaDesignCategory               Json?    // String[]
  sdaVacancyCount                 Int?
  sdaLocations                    Json?    // String[]
  sdaDetails                      Json?

  // Step 6 — Service Coverage
