  serviceMode                     String?
  multipleLocations               Json?    // branch address array

  // Step 7 — Workforce Capability
  workforceSize                   String?
  staffCapability                 Json?    // String[]
  abilityToFillUrgentShifts       Boolean  @default(false)
  workforceHiringType             String?  // INTERNAL | EXTERNAL | BOTH

  // Step 8 — Capacity & Availability
  currentCapacityStatus           String?  // OPEN | LIMITED | FULL
  abilityToPostLiveAvailability   Boolean  @default(false)

  // Step 9 — Participant Handling
  participantTypes                Json?
  participantComplexityAccepted   Json?    // String[]

  // Step 10 — Pricing & Billing
  pricingModel                    String?
  billingMethod                   String?
  travelCharges                   String?
  cancellationPolicy              String?

  // Step 11 — Platform Features
  canPostRequests                 Boolean  @default(false)
  canViewWorkerMarketplace        Boolean  @default(false)
  canPostWorkerRequirements       Boolean  @default(false)
  canPostSilSdaVacancies          Boolean  @default(false)

  // Step 12 — Profile & Branding
  businessDescription             String?
  logoUrl                         String?
  websiteUrl                      String?
  socialLinks                     Json?    // { facebook, instagram, linkedin }
  seekingPlanManager              Boolean  @default(false)

  // Step 13 — Declarations
  termsAccepted                   Boolean  @default(false)
  ndisCodeAccepted                Boolean  @default(false)
  privacyPolicyAccepted           Boolean  @default(false)
  serviceAgreementAccepted        Boolean  @default(false)
  platformRulesAccepted           Boolean  @default(false)

  availability                    ProviderAvailability[]

  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
}

