// ───────────────────────────────────────────────────────────────────────────
// Contact: one address per user (1:1). Phone is a single field on User.
// Job location is NOT here — it lives on SupportRequest.
// ───────────────────────────────────────────────────────────────────────────

model Address {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDefault       Boolean       @default(false)
  label           String?       // "Home", "Work", etc.
  unitApartment   String?
  street          String?
  suburb          String
  state           String?
  postcode        String?
  lat             Float?
  lng             Float?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
}

// ───────────────────────────────────────────────────────────────────────────
// Worker availability (weekly recurring slots + ad-hoc unavailable dates)
// ───────────────────────────────────────────────────────────────────────────

model WorkerAvailability {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  dayOfWeek       WeekDay
  startTime       String        // "09:00" 24h local
  endTime         String        // "17:00"
  createdAt       DateTime      @default(now())

  @@index([workerProfileId, dayOfWeek])
}

model WorkerUnavailability {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  date            DateTime      // a specific blocked date
  reason          String?
  createdAt       DateTime      @default(now())

  @@index([workerProfileId, date])
}

// Provider availability (weekly recurring slots — mirrors WorkerAvailability)
model ProviderAvailability {
  id                String          @id @default(uuid())
  providerProfileId String
  providerProfile   ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  dayOfWeek         WeekDay
  startTime         String          // "09:00" 24h local
  endTime           String          // "17:00"
  createdAt         DateTime        @default(now())

  @@index([providerProfileId, dayOfWeek])
}

// ───────────────────────────────────────────────────────────────────────────
// Compliance documents
// ───────────────────────────────────────────────────────────────────────────

model Document {
  id                 String          @id @default(uuid())
  userId             String
  user               User            @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  docType            DocumentType
  filePath           String
  fileName           String
  mimeType           String
  sizeBytes          Int
  referenceNumber    String?
  issueDate          DateTime?
  expiryDate         DateTime?
  status             DocumentStatus  @default(UPLOADED)
  rejectionReason    String?
  verifiedByAdminId  String?
  verifiedByAdmin    User?           @relation("DocVerifier", fields: [verifiedByAdminId], references: [id])
  verifiedAt         DateTime?
  uploadedAt         DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([expiryDate])
}

// ───────────────────────────────────────────────────────────────────────────
// Marketplace: jobs (support_requests) + applications
// ───────────────────────────────────────────────────────────────────────────

model SupportRequest {
  id                       String       @id @default(uuid())

  postedByUserId           String
  postedBy                 User         @relation("PostedBy", fields: [postedByUserId], references: [id])

  forParticipantUserId     String
  forParticipant           User         @relation("ForParticipant", fields: [forParticipantUserId], references: [id])

  title                    String
  description              String
  category                 JobCategory
  subcategory              String?
  urgency                  JobUrgency   @default(SCHEDULED)
  status                   JobStatus    @default(DRAFT)

  // Job location (the place the work happens) — distinct from any user's home address.
  suburb                   String
  state                    String
  postcode                 String?
  serviceDeliveryMode      String?

  scheduledStartAt         DateTime
  scheduledEndAt           DateTime
  totalHours               Decimal?     @db.Decimal(6, 2)
  isRecurring              Boolean      @default(false)
  recurrencePattern        Json?

  workerPreferences        Json?


  // ── Step 1: Service details ──────────────────────────────────────────────────
  supportGoal          String?       // e.g. DAILY_LIVING, INDEPENDENCE, SOCIAL_PARTICIPATION
  durationType         String?       // ONE_TIME | TEMPORARY | RECURRING | ONGOING | TRIAL | EMERGENCY
  participantPostedAs  String?       // SELF | NOMINEE | FAMILY | COORDINATOR | GUARDIAN

  // ── Step 2: Schedule ─────────────────────────────────────────────────────────
  shiftType            ShiftType?
  timeFlexibility      String?       // EXACT | FLEXIBLE_SLIGHT | FLEXIBLE_MORNING | FLEXIBLE_AFTERNOON | FLEXIBLE_EVENING | FLEXIBLE_ANYTIME | DISCUSS
  applicationDeadlineAt DateTime?

  // ── Step 3: Location (extended) ───────────────────────────────────────────────
  addressLine          String?       // unit/street (full address, shown only after booking)
  locationNotes        String?       // access notes: stairs, parking, pets, etc.
  lat                  Decimal?      @db.Decimal(9, 6)
  lng                  Decimal?      @db.Decimal(9, 6)
  travelRequired       String?       // NONE | LOCAL | MULTI_STOP | PARTICIPANT_TRANSPORT | LONG_DISTANCE

  // ── Step 6: Budget / Funding ──────────────────────────────────────────────────
  fundingType          FundingType?
  budgetType           String?       // FIXED_HOURLY | FIXED_TOTAL | OPEN | NDIS | DISCUSS
  budgetPerHour        Decimal?      @db.Decimal(8, 2)
  totalBudget          Decimal?      @db.Decimal(10, 2)
  travelReimbursement  String?       // INCLUDED | ADDITIONAL | DISCUSS | NOT_REQUIRED

  // ── Step 7: Visibility ───────────────────────────────────────────────────────
  visibilityTarget     String?       // ALL | VERIFIED | PROVIDERS_ONLY | WORKERS_ONLY | INVITE_ONLY
  maxApplicants        Int?
  hideParticipantName  Boolean       @default(false)
  allowQuotes          Boolean       @default(false)
  allowDirectMessages  Boolean       @default(true)

  // ── Coordinator / Plan Manager extras ────────────────────────────────────────
  internalNote         String?       // private — never shown publicly
  caseReference        String?       // coordinator case ref
  requestPurposeCategory String?     // NEW_SUPPORT | REPLACEMENT | URGENT_INTERIM | HOSPITAL_DISCHARGE | etc.

  // The candidate (worker OR provider) the poster selected from the top-5.
  selectedApplicantUserId  String?
  selectedApplicant        User?        @relation("SelectedApplicant", fields: [selectedApplicantUserId], references: [id])
  // For provider-selected jobs: the actual worker the provider assigns afterwards.
  assignedWorkerUserId     String?
  assignedWorker           User?        @relation("AssignedWorker", fields: [assignedWorkerUserId], references: [id])

  selectedAt               DateTime?
  startedAt                DateTime?
  completedAt              DateTime?
  confirmedAt              DateTime?
  cancelledAt              DateTime?
  cancelledByUserId        String?
  cancelledBy              User?        @relation("CancelledBy", fields: [cancelledByUserId], references: [id])
  cancelReason             String?

  // True when this job was reopened+escalated to EMERGENCY by a near-start cancellation.
  promotedFromCancellation Boolean      @default(false)
  // Set to true once the 15-min pre-start notification has been sent to the assigned worker.
  assignedWorkerNotified   Boolean      @default(false)

  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  applications             JobApplication[]
  messages                 JobMessage[]
  invoices                 Invoice[]

  @@index([status])
  @@index([urgency])
  @@index([suburb])
  @@index([category])
  @@index([postedByUserId])
  @@index([forParticipantUserId])
  @@index([selectedApplicantUserId])
  @@index([assignedWorkerUserId])
  @@index([shiftType])
  @@index([fundingType])
  @@index([isRecurring])
  @@index([visibilityTarget])
  @@index([applicationDeadlineAt])
  // Compound indexes for listMyJobs — covers (userId, status) filters together
  @@index([postedByUserId, status])
  @@index([assignedWorkerUserId, status])
  @@index([selectedApplicantUserId, status])
}

model JobApplication {
  id              String            @id @default(uuid())
  jobId           String
  job             SupportRequest    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantUserId String
  applicant       User              @relation(fields: [applicantUserId], references: [id])
  // Worker (solo) or Provider (business). Stored for convenience in ranking.
  applicantRole   UserRole
  score           Float             @default(0)  // multi-factor ranking score
  status          ApplicationStatus @default(INTERESTED)
  note            String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt


  // ── Structured application proposal ──────────────────────────────────────────
  availabilityType     String?   // YES_EXACT | YES_ADJUSTED | PARTIAL | DISCUSS | UNAVAILABLE
  rateResponse         String?   // ACCEPT | OFFER_OWN | QUOTE_AFTER | DISCUSS
  proposedRate         Decimal?  @db.Decimal(8, 2)
  introduction         String?   // longer proposal text (separate from note)
  applicationData      Json?     // suitability confirmations, doc visibility, etc.

  @@unique([jobId, applicantUserId])
  @@index([jobId, status])
  @@index([applicantUserId])
}

model JobMessage {
  id            String         @id @default(uuid())
  jobId         String
  job           SupportRequest @relation(fields: [jobId], references: [id], onDelete: Cascade)
  senderUserId  String
  sender        User           @relation(fields: [senderUserId], references: [id])
  body          String
  createdAt     DateTime       @default(now())

  @@index([jobId, createdAt])
}

// ───────────────────────────────────────────────────────────────────────────
// Invoice = in-app completion record (NOT a PDF, NOT a payment).
// Sender manually sends it to the relevant Plan Manager, who coordinates by phone.
// ───────────────────────────────────────────────────────────────────────────

model Invoice {
  id                 String   @id @default(uuid())
  jobId              String
  job                SupportRequest @relation(fields: [jobId], references: [id], onDelete: Cascade)

  senderUserId       String   // who triggered the send (coordinator / provider / solo actor)
  sender             User     @relation("InvoiceSender", fields: [senderUserId], references: [id])

  planManagerUserId  String   // recipient PM
  planManager        User     @relation("InvoicePlanManager", fields: [planManagerUserId], references: [id])

  participantUserId  String   // the participant the work was for
  participant        User     @relation("InvoiceParticipant", fields: [participantUserId], references: [id])

  hours              Decimal? @db.Decimal(6, 2)
  note               String?
  sentAt             DateTime @default(now())
  createdAt          DateTime @default(now())

  @@index([planManagerUserId, sentAt])
  @@index([senderUserId])
  @@index([jobId])
}

// ───────────────────────────────────────────────────────────────────────────
// Plan Manager discovery + connection (mutual accept, either side initiates)
// ───────────────────────────────────────────────────────────────────────────

model PlanManagerConnection {
  id                 String             @id @default(uuid())
  planManagerUserId  String
  planManager        User               @relation("PmConnManager", fields: [planManagerUserId], references: [id], onDelete: Cascade)
  clientUserId       String             // participant / worker / provider
  client             User               @relation("PmConnClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  status             PmConnectionStatus @default(PENDING)
  initiatedBy        PmInitiator
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([planManagerUserId, clientUserId])
  @@index([planManagerUserId, status])
  @@index([clientUserId, status])
}

// ───────────────────────────────────────────────────────────────────────────
// In-app notifications
// ───────────────────────────────────────────────────────────────────────────

model Notification {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  title      String
  body       String?
  data       Json?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ───────────────────────────────────────────────────────────────────────────
// Admin audit log
// ───────────────────────────────────────────────────────────────────────────

model AuditLog {
  id               String       @id @default(uuid())
  adminUserId      String
  admin            User         @relation("AdminAction", fields: [adminUserId], references: [id])
  action           AuditAction
  targetUserId     String?
  targetUser       User?        @relation("AuditTarget", fields: [targetUserId], references: [id])
  targetDocumentId String?
  reason           String?
  metadata         Json?
  createdAt        DateTime     @default(now())

  @@index([adminUserId, createdAt])
  @@index([targetUserId])
}

// ───────────────────────────────────────────────────────────────────────────
// Subscription plans (seeded rows — Stripe prices added in Phase 2)
// ───────────────────────────────────────────────────────────────────────────

model Plan {
  id              String   @id @default(uuid())
  // Machine key, e.g. WORKER_BASIC, PROVIDER_PRO
  key             String   @unique
  // The role this plan applies to
  role            UserRole
  name            String
  amountAud       Decimal  @db.Decimal(10, 2)
  // Stripe price ID — null until Phase 2 swap-in
  stripePriceId   String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  subscriptions   UserSubscription[]

  @@index([role, active])
}

model UserSubscription {
  id                     String             @id @default(uuid())
  userId                 String
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                 String
  plan                   Plan               @relation(fields: [planId], references: [id])
  status                 SubscriptionStatus @default(ACTIVE)
  // Stripe subscription ID — null until Phase 2 swap-in
  stripeSubscriptionId   String?
  // Fake payment reference (Phase 1 mock)
  mockReceiptRef         String?
  activatedAt            DateTime           @default(now())
  expiresAt              DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([userId, status])
  @@index([planId])
}

// ───────────────────────────────────────────────────────────────────────────
// Auth: sessions + OTP / verification codes
// ───────────────────────────────────────────────────────────────────────────

model Session {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String   @unique
  // The immediately-prior refresh token hash, kept valid for a short grace
  // window after rotation so that two near-simultaneous refresh requests
  // (e.g. rapid full-page navigations) don't log the user out.
  previousRefreshTokenHash      String?   @unique
  previousRefreshTokenExpiresAt DateTime?
  expiresAt        DateTime
  activeRole       UserRole?
  userAgent        String?
  ip                 String?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ───────────────────────────────────────────────────────────────────────────
// OTP / password-reset codes (email + SMS — mock sender in dev)
// ───────────────────────────────────────────────────────────────────────────

model VerificationCode {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     OtpChannel
  purpose     OtpPurpose
  destination String
  codeHash    String
  attempts    Int        @default(0)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime   @default(now())
 
  @@index([userId, purpose])
  @@index([expiresAt])
}
