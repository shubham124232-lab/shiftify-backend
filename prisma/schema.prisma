// ───────────────────────────────────────────────────────────────────────────
// Core: User + roles + role profile extensions
// ───────────────────────────────────────────────────────────────────────────

model User {
  id                      String       @id @default(uuid())

  // Identity — all nullable. SELF accounts use email/phone (and may set a username);
  // MANAGED accounts use username only. Unique where present (Postgres allows many NULLs).
  email                   String?      @unique
  phone                   String?      @unique   // single E.164 number per user
  username                String?      @unique
  passwordHash            String?
  name                    String

  accountType             AccountType  @default(SELF)
  status                  UserStatus   @default(PENDING)
  adminTier               AdminTier?
  rejectionReason         String?
  avatarUrl               String?

  defaultSuburb           String?
  defaultState            String?
  defaultPostcode         String?

  // MANAGED accounts (provider→worker, coordinator→participant) point at their creator.
  parentUserId            String?
  parent                  User?        @relation("ChildToParent", fields: [parentUserId], references: [id])
  children                User[]       @relation("ChildToParent")

  // Multi-role: a SELF account can hold many roles. The active role lives in the JWT,
  // not here — UserRoleAssignment is the source of truth for which roles a user holds.
  roles                   UserRoleAssignment[]

  emailVerified           Boolean      @default(false)
  phoneVerified           Boolean      @default(false)

  // Guest window for self-registered participants — now keyed off email verification (OTP),
  // not magic links.
  guestUntil              DateTime?
  lastGuestReminderAt     DateTime?

  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  // Relations
  addresses               Address[]
  documents               Document[]   @relation("UserDocuments")
  verificationCodes       VerificationCode[]
  participantProfile      ParticipantProfile?
  workerProfile           WorkerProfile?
  providerProfile         ProviderProfile?
  coordinatorProfile      CoordinatorProfile?
  planManagerProfile      PlanManagerProfile?

  jobsPosted              SupportRequest[]  @relation("PostedBy")
  jobsForMe               SupportRequest[]  @relation("ForParticipant")
  jobsSelected            SupportRequest[]  @relation("SelectedApplicant")
  jobsAssigned            SupportRequest[]  @relation("AssignedWorker")
  jobsCancelled           SupportRequest[]  @relation("CancelledBy")
  jobApplications         JobApplication[]

  messagesSent            JobMessage[]
  notifications           Notification[]
  sessions                Session[]

  auditLogActions         AuditLog[]   @relation("AdminAction")
  auditLogTargets         AuditLog[]   @relation("AuditTarget")
  documentsVerifiedByMe   Document[]   @relation("DocVerifier")

  subscriptions           UserSubscription[]

  invoicesSent            Invoice[]    @relation("InvoiceSender")
  invoicesReceived        Invoice[]    @relation("InvoicePlanManager")
  invoicesAsParticipant   Invoice[]    @relation("InvoiceParticipant")

  pmConnectionsAsManager  PlanManagerConnection[] @relation("PmConnManager")
  pmConnectionsAsClient   PlanManagerConnection[] @relation("PmConnClient")

  @@index([status])
  @@index([accountType])
  @@index([parentUserId])
  @@index([guestUntil])
}

// Multi-role mapping. One row per (user, role). `isActiveDefault` marks the role the
// dashboard opens on after login; the in-session active role is carried in the JWT.
model UserRoleAssignment {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            UserRole
  isActiveDefault Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([userId, role])
  @@index([role])
}

model ParticipantProfile {
  id                            String   @id @default(uuid())
  userId                        String   @unique
  user                          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  profileStep                   Int      @default(0)

  // Step 1 — Personal Info
  preferredName                 String?
  participantType               String?  // SELF | PARENT | GUARDIAN | CARER | NOMINEE
  ageGroup                      String?
  gender                        String?
  suburb                        String?
  postcode                      String?
  state                         String?
  fullAddress                   String?

  // Step 2 — NDIS Details
  ndisNumber                    String?
  fundingManagementType         String?  // SELF_MANAGED | PLAN_MANAGED | NDIA_MANAGED
  supportCoordinationFunding    String?  // NONE | LEVEL_1 | LEVEL_2 | LEVEL_3
  ndisStartDate                 DateTime?
  ndisEndDate                   DateTime?

  // Step 3 — Support Needs
  primaryDisability             String?
  primarySupportNeeds           Json?    // String[] — service categories required
  preferredSupportType          String?  // ONE_TIME | ONGOING | BOTH
  mobilitySupportNeeds          Json?
  communicationNeeds            Json?
  behaviourSensoryNotes         Json?
  medicalConsiderations         Json?
  riskSafetyNotes               String?
  supportPreferences            Json?

  // Step 4 — Preferences & Availability
  preferredWorkerGender         String?
  languagePreference            Json?    // String[]
  culturalPreference            Json?    // String[]
  skillsRequired                Json?    // String[]
  preferredDays                 Json?    // String[]
  preferredTime                 Json?    // String[] — MORNING | AFTERNOON | EVENING | OVERNIGHT

  // Step 5 — Emergency Contact
  emergencyContactName          String?
  emergencyContactPhone         String?
  emergencyContactRelationship  String?

  // PM linkage now lives in PlanManagerConnection. This flag drives discovery.
  seekingPlanManager            Boolean  @default(false)

  // Step 6 — Declaration
  termsAccepted                 Boolean  @default(false)
  privacyPolicyAccepted         Boolean  @default(false)
  ndisCodeAccepted              Boolean  @default(false)

  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model WorkerProfile {
  id                        String   @id @default(uuid())
  userId                    String   @unique
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  profileStep               Int      @default(0)

  // Step 1 — Identity
  dob                       DateTime?
  gender                    String?
  suburb                    String?
  postcode                  String?
  state                     String?

  // Step 2 — Right to Work
  rightToWork               String?
  visaType                  String?
  visaExpiry                DateTime?

  // Step 3 — Compliance Metadata
  ndisScreeningNumber           String?
  ndisScreeningExpiry           DateTime?
  policeCheckIssueDate          DateTime?
  policeCheckExpiry             DateTime?
  wwccNumber                    String?
  wwccExpiry                    DateTime?
  firstAidExpiry                DateTime?
  cprExpiry                     DateTime?
  driversLicenceExpiry          DateTime?
  infectionControlCompleted     Boolean  @default(false)

  // Step 4 — Work Type & Insurance
  workType                      String?
  abn                           String?
  gstRegistered                 Boolean  @default(false)
  publicLiabilityInsurance      Boolean  @default(false)
  publicLiabilityPolicyNumber   String?
  publicLiabilityExpiry         DateTime?
  personalAccidentInsurance      Boolean  @default(false)
  personalAccidentPolicyNumber   String?
  personalAccidentExpiry         DateTime?
  driversLicenceType            String?  // C | R | HR | HC | MR

  // Step 5 — Services & Skills
  servicesOffered           Json?
  subServices               Json?
  highIntensitySkills       Json?
  experienceLevel           String?
  disabilityExperience      Json?

  // Step 6 — Availability
  availabilityType          String?
  availableDays             Json?    // String[] — MON | TUE | WED | THU | FRI | SAT | SUN
  timeBlocks                Json?    // String[] — MORNING | AFTERNOON | EVENING | OVERNIGHT
  emergencyAvailability     Boolean  @default(false)
  sleeperAvailability       Boolean  @default(false)
  minimumShiftHours         Float?

  // Step 7 — Service Areas & Travel
  serviceAreas              Json?
  travelRadiusKm            Int?
  hasVehicle                Boolean  @default(false)
  canTransportParticipants  Boolean  @default(false)
  insuranceValid            Boolean  @default(false)
  vehicleDetails            Json?    // { make, model, year, rego, colour }

  // Step 8 — Financials, Bio & Preferences
  hourlyRate                Decimal? @db.Decimal(10, 2)
  hourlyRateType            String?  // FIXED | NDIS_PRICE_GUIDE | NEGOTIABLE
  weekendNightRates         Json?    // { weekendRate, nightRate, publicHolidayRate }
  travelCharges             String?  // NONE | INCLUDED | CHARGED_SEPARATELY
  preferredParticipantType  Json?    // String[]
  genderPreference          String?
  languagesSpoken           Json?    // String[]
  bio                       String?
  preferences               String?
  isAvailableNow            Boolean  @default(false)
  seekingPlanManager        Boolean  @default(false)

  // Step 9 — Documents
  manualHandlingCompleted   Boolean  @default(false)
  firstAidCertType          String?  // HLTAID011 | HLTAID009 | OTHER

  // Step 10 — Compliance
  termsAccepted             Boolean  @default(false)
  ndisCodeAccepted          Boolean  @default(false)
  privacyPolicyAccepted     Boolean  @default(false)
  declarationStatement      Boolean  @default(false)

  // Stats
  rating                    Float    @default(0)
  totalReviews              Int      @default(0)
  lat                       Float?
  lng                       Float?

  // Referee contacts — JSON array of { name, relationship, phone, email }
  references                Json?

  availability              WorkerAvailability[]
  unavailability            WorkerUnavailability[]

  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

