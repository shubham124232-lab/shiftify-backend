  abn                             String?  @unique
  businessStructure               String?
  ndisRegistered                  Boolean  @default(false)
  ndisProviderNumber              String?
  gstRegistered                   Boolean  @default(false)
  yearsInOperation                String?

  // Step 3 — Key Contacts
  primaryContactName              String?
  primaryContactRole              String?
  primaryContactPhone             String?
  primaryContactEmail             String?
  secondaryContactName            String?
  secondaryContactRole            String?
  secondaryContactPhone           String?
  secondaryContactEmail           String?
  accountsContactName             String?
  accountsContactEmail            String?

  // Step 4 — Compliance (policy metadata)
