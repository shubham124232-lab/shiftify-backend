# Server
NODE_ENV=development
PORT=5000

# Database (PostgreSQL 16)
#
# --- Neon (cloud) ---
# DATABASE_URL = the POOLED connection (host contains "-pooler"); used by the app at runtime.
# DIRECT_URL   = the DIRECT (non-pooled) connection; used by `prisma migrate`.
# Both must end with ?sslmode=require. Get both from the Neon dashboard → Connection Details.
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"
#
# --- Local Postgres (no Neon) ---
# Set DIRECT_URL to the SAME value as DATABASE_URL.
DATABASE_URL="postgresql://postgres:your-password@localhost:5432/shiftify_dev?schema=public"
DIRECT_URL="postgresql://postgres:your-password@localhost:5432/shiftify_dev?schema=public"

# JWT
JWT_ACCESS_SECRET=replace-me-with-a-32-byte-hex-string
JWT_REFRESH_SECRET=replace-me-with-another-32-byte-hex-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS — Web (3000) and future Admin/Flutter
CORS_ORIGIN=http://localhost:3000

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_BYTES=26214400

# Staging only: return OTP codes in API responses + enable /auth/dev/inbox while
# no real SMS/email provider is configured. MUST be false/removed once Twilio/Resend go live.
RETURN_DEV_OTP=false

# Seed (used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@shiftify.local
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=Shiftify Admin



